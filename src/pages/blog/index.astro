---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog'))
	.filter(post => !post.data.draft || import.meta.env.DEV)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Blog — Umar Farouk Yunusa" description="Technical articles on backend engineering, PHP, AI systems, architecture, and developer tools.">
	<section class="space-y-8 py-4">
		<div>
			<h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl mb-4">
				Blog
			</h1>
			<p class="text-muted-custom max-w-[600px] text-sm">
				Writing about building scalable backend systems, AI workflows, developer productivity, and open-source tooling.
			</p>
		</div>

		<div class="pt-6 border-t border-border-custom">
			{posts.length === 0 ? (
				<p class="text-muted-custom py-4 text-sm">No blog posts found.</p>
			) : (
				<ul class="space-y-10">
					{posts.map((post) => (
						<li class="group">
							<article class="space-y-2">
								<div class="flex flex-col sm:flex-row sm:items-baseline justify-between gap-1">
									<h2 class="text-lg font-bold">
										<a href={`/blog/${post.id}`} class="hover:text-accent-custom transition-colors">
											{post.data.title}
										</a>
									</h2>
									<span class="text-xs text-muted-custom font-medium whitespace-nowrap">
										<FormattedDate date={post.data.date} />
									</span>
								</div>
								
								<p class="text-sm text-muted-custom leading-relaxed line-clamp-2">
									{post.data.description}
								</p>

								{post.data.tags && post.data.tags.length > 0 && (
									<div class="flex flex-wrap gap-2 pt-1">
										{post.data.tags.map((tag) => (
											<span class="text-[10px] font-semibold bg-border-custom/30 text-accent-custom px-2 py-0.5 rounded border border-border-custom">
												#{tag}
											</span>
										))}
										{post.data.draft && (
											<span class="text-[10px] font-semibold bg-amber-500/10 text-amber-500 px-2 py-0.5 rounded border border-amber-500/20">
												Draft
											</span>
										)}
									</div>
								)}
							</article>
						</li>
					))}
				</ul>
			)}
		</div>
	</section>
</Layout>
