---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<section class="space-y-8 py-4">
		<!-- Hero Section -->
		<div class="space-y-4">
			<h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl">
				Umar Farouk Yunusa
			</h1>
			<p class="text-lg text-muted-custom font-medium max-w-[600px] leading-relaxed">
				Senior Backend & AI Engineer based in Nigeria. Building high-throughput fintech systems and production-grade AI pipelines.
			</p>
			
			<div class="flex flex-wrap gap-4 text-sm font-medium pt-2">
				<a href="https://github.com/fyunusa" target="_blank" rel="noopener noreferrer" class="text-accent-custom hover:underline">GitHub</a>
				<span class="text-border-custom">|</span>
				<a href="https://linkedin.com/in/umar-yunusa-1463a418b" target="_blank" rel="noopener noreferrer" class="text-accent-custom hover:underline">LinkedIn</a>
				<span class="text-border-custom">|</span>
				<a href="https://x.com/realdevhq" target="_blank" rel="noopener noreferrer" class="text-accent-custom hover:underline">X / Twitter</a>
				<span class="text-border-custom">|</span>
				<a href="https://realdevhq.com" target="_blank" rel="noopener noreferrer" class="text-accent-custom hover:underline">Real Dev</a>
			</div>
		</div>

		<!-- Biography Section -->
		<div class="space-y-6 pt-4 border-t border-border-custom">
			<p class="text-base leading-relaxed opacity-95">
				I am a software engineer with 7+ years of experience specialized in constructing robust backend systems, scaling microservices, and orchestrating production AI workflows. I design high-throughput systems, contribute to open-source developer tooling, and write about the engineering of reliable software.
			</p>
		</div>

		<!-- Main Nav List -->
		<div class="pt-6">
			<h2 class="text-xs font-semibold uppercase tracking-wider text-muted-custom mb-3">Explore</h2>
			<ul class="space-y-3">
				<li>
					<a href="/about" class="group flex items-baseline gap-2">
						<span class="font-medium hover:text-accent-custom transition-colors border-b border-dashed border-muted-custom group-hover:border-accent-custom">About Me</span>
						<span class="text-xs text-muted-custom opacity-80">&mdash; My journey, technical career facts, and core values</span>
					</a>
				</li>
				<li>
					<a href="/blog" class="group flex items-baseline gap-2">
						<span class="font-medium hover:text-accent-custom transition-colors border-b border-dashed border-muted-custom group-hover:border-accent-custom">Blog</span>
						<span class="text-xs text-muted-custom opacity-80">&mdash; Thoughts on backend systems, LLMs, and open-source tools</span>
					</a>
				</li>
				<li>
					<a href="/projects" class="group flex items-baseline gap-2">
						<span class="font-medium hover:text-accent-custom transition-colors border-b border-dashed border-muted-custom group-hover:border-accent-custom">Projects</span>
						<span class="text-xs text-muted-custom opacity-80">&mdash; Open source packages, extensions, and commercial AI apps</span>
					</a>
				</li>
				<li>
					<a href="/resume" class="group flex items-baseline gap-2">
						<span class="font-medium hover:text-accent-custom transition-colors border-b border-dashed border-muted-custom group-hover:border-accent-custom">Resume</span>
						<span class="text-xs text-muted-custom opacity-80">&mdash; Professional history, technology stacks, and print-friendly export</span>
					</a>
				</li>
			</ul>
		</div>
	</section>
</Layout>
