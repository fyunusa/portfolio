---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-16 py-4">
		<!-- Left / Main Column: Hero & Bio -->
		<div class="lg:col-span-2 space-y-8">
			<div class="space-y-4">
				<h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight">
					Umar Yunusa
				</h1>
				<p class="text-lg sm:text-xl text-muted-custom font-medium max-w-[620px] leading-relaxed">
					Senior Backend Engineer based in Nigeria. Building high-performance, secure systems across fintech, e-commerce, and RAG/AI platforms.
				</p>
				
				<div class="flex flex-wrap gap-4 text-sm font-semibold pt-2 no-print">
					<a href="https://github.com/fyunusa" target="_blank" rel="noopener noreferrer" class="text-accent-custom hover:text-teal-500 transition-colors">GitHub</a>
					<span class="text-border-custom">|</span>
					<a href="https://linkedin.com/in/umar-yunusa-1463a418b" target="_blank" rel="noopener noreferrer" class="text-accent-custom hover:text-teal-500 transition-colors">LinkedIn</a>
					<span class="text-border-custom">|</span>
					<a href="https://x.com/techguyumar" target="_blank" rel="noopener noreferrer" class="text-accent-custom hover:text-teal-500 transition-colors">X / Twitter</a>
					<span class="text-border-custom">|</span>
					<a href="https://www.youtube.com/@real_dev_hq" target="_blank" rel="noopener noreferrer" class="text-accent-custom hover:text-teal-500 transition-colors">Real Dev (YouTube)</a>
				</div>
			</div>

			<div class="space-y-6 pt-6 border-t border-border-custom">
				<p class="text-base sm:text-lg leading-relaxed opacity-95 text-muted-custom">
					I am a software engineer with 7+ years of experience specializing in constructing robust backend systems, scaling microservices, and orchestrating production AI workflows. I design high-throughput systems, contribute to open-source developer tooling, and write about the engineering of reliable software.
				</p>
			</div>
		</div>

		<!-- Right Column: Explore Links (dashboard design) -->
		<div class="space-y-6 lg:border-l lg:border-border-custom lg:pl-10">
			<h2 class="text-xs font-bold uppercase tracking-wider text-muted-custom">Explore</h2>
			<ul class="space-y-4">
				<li>
					<a href="/about" class="group block p-4 rounded-xl border border-border-custom bg-card-bg hover:border-accent-custom hover:shadow-xs transition-all duration-300">
						<span class="block font-bold text-fg-custom group-hover:text-accent-custom transition-colors duration-200">About Me</span>
						<span class="block text-xs text-muted-custom mt-1 leading-relaxed">My journey, technical milestones, and career facts.</span>
					</a>
				</li>
				<li>
					<a href="/blog" class="group block p-4 rounded-xl border border-border-custom bg-card-bg hover:border-accent-custom hover:shadow-xs transition-all duration-300">
						<span class="block font-bold text-fg-custom group-hover:text-accent-custom transition-colors duration-200">Blog</span>
						<span class="block text-xs text-muted-custom mt-1 leading-relaxed">Thoughts on backend systems, LLMs, and open-source.</span>
					</a>
				</li>
				<li>
					<a href="/projects" class="group block p-4 rounded-xl border border-border-custom bg-card-bg hover:border-accent-custom hover:shadow-xs transition-all duration-300">
						<span class="block font-bold text-fg-custom group-hover:text-accent-custom transition-colors duration-200">Projects</span>
						<span class="block text-xs text-muted-custom mt-1 leading-relaxed">Open source packages, CLI tools, and commercial AI apps.</span>
					</a>
				</li>
				<li>
					<a href="/resume" class="group block p-4 rounded-xl border border-border-custom bg-card-bg hover:border-accent-custom hover:shadow-xs transition-all duration-300">
						<span class="block font-bold text-fg-custom group-hover:text-accent-custom transition-colors duration-200">Resume</span>
						<span class="block text-xs text-muted-custom mt-1 leading-relaxed">Professional history, skills, and PDF download.</span>
					</a>
				</li>
			</ul>
		</div>
	</div>
</Layout>
